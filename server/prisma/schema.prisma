generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id        String        @id @default(uuid())
  service   String
  dateTime  String
  name      String
  email     String
  phone     String
  address   String
  notes     String?
  status    BookingStatus @default(PENDING)
  createdAt DateTime      @default(now())
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
}
